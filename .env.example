# Required: get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Required: your public Render URL, no trailing slash
# Example: https://fixora-telegram-gpt.onrender.com
ISSUER=

# Render sets PORT automatically, but default is safe
PORT=3000

# Strong random admin token for /api/stats and /api/import-session
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=

# Storage. For Render persistent disk, use /app/data/cloud.db
DATABASE_PATH=/app/data/cloud.db

# Privacy-first logs: local-only means no outbound telemetry
MCP_TELEGRAM_TELEMETRY=local-only
LOG_HASH_SALT=

# Optional branding/contact
BRAND_NAME=Fixora Telegram GPT
CONTACT_EMAIL=
CONTACT_TELEGRAM=

# Optional OpenAI Apps domain verification
OPENAI_APPS_CHALLENGE=

# Optional bot broadcast. Leave blank unless needed.
BOT_TOKEN=
BOT_USERNAME=
BOT_WEBHOOK_SECRET=
